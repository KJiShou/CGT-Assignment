  m_Script: {fileID: 11500000, guid: f9203a3b4efa96c40a519d4befc4a8cd, type: 3}
  m_Name: Neuroticism
  m_EditorClassIdentifier: Assembly-CSharp::TraitDictionarySO
  traitName: Neuroticism
  levels:
  - minThreshold: 0.6
    shortLabel: Volatile
    detailedDescription: Emotionally highly unstable; the slightest disturbance can
      trigger severe anxiety or a breakdown.
  - minThreshold: 0.2
    shortLabel: Anxious
    detailedDescription: Prone to experiencing negative emotions, easily becoming
      tense or depressed under pressure.
  - minThreshold: -0.2
    shortLabel: Balanced
    detailedDescription: Possesses a normal range of emotional fluctuation and is
      capable of handling daily stress.
  - minThreshold: -0.6
    shortLabel: Composed
    detailedDescription: Highly resilient, maintaining a calm and clear head even
      in moments of crisis.
  - minThreshold: -1
    shortLabel: Stoic
    detailedDescription: Like an emotionless machine, feeling almost no fear, anxiety,
      or sadness.

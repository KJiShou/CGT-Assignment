  m_Script: {fileID: 11500000, guid: f9203a3b4efa96c40a519d4befc4a8cd, type: 3}
  m_Name: Conscientiousness
  m_EditorClassIdentifier: Assembly-CSharp::TraitDictionarySO
  traitName: Conscientiousness
  levels:
  - minThreshold: 0.6
    shortLabel: Meticulous
    detailedDescription: Possesses extreme self-discipline and a strong sense of
      responsibility, striving for perfection with machine-like precision.
  - minThreshold: 0.2
    shortLabel: Reliable
    detailedDescription: A dependable executor who typically completes assigned tasks
      efficiently.
  - minThreshold: -0.2
    shortLabel: Spontaneous
    detailedDescription: Lacks strict planning, acting based on their current mood
      and state of mind.
  - minThreshold: -0.6
    shortLabel: Disorganized
    detailedDescription: Highly unorganized, frequently forgetting things or botching
      tasks, making them hard to trust.
  - minThreshold: -1
    shortLabel: Reckless
    detailedDescription: Acts extremely impulsively without regard for consequences,
      treating rules and responsibilities as non-existent.

  m_Script: {fileID: 11500000, guid: f9203a3b4efa96c40a519d4befc4a8cd, type: 3}
  m_Name: Openness
  m_EditorClassIdentifier: Assembly-CSharp::TraitDictionarySO
  traitName: Openness
  levels:
  - minThreshold: 0.6
    shortLabel: Visionary
    detailedDescription: Possesses boundless imagination, is intensely passionate
      about the unknown, and deeply despises conventionality.
  - minThreshold: 0.2
    shortLabel: Open-Minded
    detailedDescription: Flexible in thinking, willing to embrace new concepts and
      experiences.
  - minThreshold: -0.2
    shortLabel: Neutral
    detailedDescription: Maintains a neutral stance towards new things; neither rejects
      them nor actively seeks them out.
  - minThreshold: -0.6
    shortLabel: Traditional
    detailedDescription: Prefers familiar environments and established rules, feeling
      uncomfortable with drastic changes.
  - minThreshold: -1
    shortLabel: Closed-Minded
    detailedDescription: Extremely closed-off intellectually, strongly rejecting
      any new ideas or foreign concepts.
